# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=False

# Database
DATABASE_URL=sqlite:///users.db
# For PostgreSQL: postgresql://user:password@localhost:5432/traffic_db

# Application
MAX_CONTENT_LENGTH=16777216  # 16MB max file upload
SESSION_TIMEOUT=3600  # 1 hour

# Model Configuration
MODEL_PATH=./saved_models/st_mlp.pth
SCALER_PATH=./saved_models/scaler.pkl
STATIC_SCALER_PATH=./saved_models/static_scaler.pkl
SENSOR_IDS_PATH=./saved_models/sensor_ids.pkl

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security
ENABLE_CORS=False
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5000
RATE_LIMIT=100/hour
